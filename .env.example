APP_ENV=development
APP_NAME=GuardedRAG API
APP_VERSION=0.1.0
SERVICE_NAME=guardedrag

# Optional provider key. Keep real values only in local .env files.
OPENAI_API_KEY=

EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini

VECTOR_STORE_PATH=data/vector_store
TOP_K=5
SIMILARITY_THRESHOLD=0.75
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
